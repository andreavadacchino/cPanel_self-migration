# PostgreSQL
POSTGRES_USER=migration
POSTGRES_PASSWORD=migration
POSTGRES_DB=migration
# Host ports published by docker compose. Override these if the host already
# runs a local Postgres/Redis on the default ports.
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
WEB_PORT=5173

# API
DATABASE_URL=postgresql+psycopg://migration:migration@postgres:5432/migration
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:5173
# Required before storing direct cPanel tokens. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
# Set true only for local debugging without a worker. Production should remain false.
PREFLIGHT_INLINE=false
# Safety switch for domain writes. Allowed values: "disabled" (default), "mock"
# (simulated writer path), "enabled" (real destination writer — B3b-ii). "enabled"
# is inert unless REAL_EXECUTION_MODE=enabled too (double gate). Any other value
# (including the retired "real") is rejected fail-closed at startup.
DOMAIN_WRITER_MODE=disabled
DATABASE_WRITER_MODE=disabled
MYSQL_USER_WRITER_MODE=disabled
# Safety switch for the email forwarder writer. Allowed values: "disabled"
# (default), "mock" (simulated writer path), "enabled" (real additive writer,
# task B4a). "enabled" is inert unless REAL_EXECUTION_MODE=enabled too (double
# gate) and is not yet wired into the runtime dispatch until B4e. Any other value
# is rejected fail-closed at startup.
FORWARDER_WRITER_MODE=disabled
# Safety switch for the default (catch-all) address writer. Allowed values:
# "disabled" (default), "mock", "enabled" (real compensable writer, tasks
# B4b-i/B4b-ii). "enabled" is inert unless REAL_EXECUTION_MODE=enabled too (double
# gate); B4b-i only builds the evidence contract and pure rules (no write), and the
# writer is not wired into the runtime dispatch until B4e. Any other value is
# rejected fail-closed at startup.
DEFAULT_ADDRESS_WRITER_MODE=disabled
# Safety switch for the email routing (mail-route) writer. Allowed values:
# "disabled" (default), "mock", "enabled" (real compensable writer, tasks
# B4c-i/B4c-ii). "enabled" is inert unless REAL_EXECUTION_MODE=enabled too (double
# gate); B4c-i only builds the evidence contract, classification and the pure
# evidence-bound policy/rules (no write), and the writer is not wired into the
# runtime dispatch until B4e. Any other value is rejected fail-closed at startup.
ROUTING_WRITER_MODE=disabled
CRON_WRITER_MODE=disabled
FTP_WRITER_MODE=disabled
MAILING_LIST_WRITER_MODE=disabled
DNS_WRITER_MODE=disabled
AUTORESPONDER_WRITER_MODE=disabled
MOCK_ORCHESTRATOR_MODE=disabled
# Master switch for the real (non-dry-run) execution contract. Only "disabled"
# and "enabled" are accepted; keep it disabled unless an authorized environment
# has explicitly opted in. Disabled means no real attempt or lease can be opened,
# and the real dispatch endpoint (POST /api/executions/{id}/dispatch) and its
# worker actor both fail closed. No route or UI can change this flag.
REAL_EXECUTION_MODE=disabled
# Time-to-live (seconds) of a destination-account execution lease. The holder
# must heartbeat within this window; a lapsed lease can be taken over with a
# bumped fencing token.
EXECUTION_LEASE_TTL_SECONDS=300
# Maximum age (seconds) of a strong confirmation before a real write phase must
# be re-confirmed. The safety gate rejects an older confirmation.
REAL_CONFIRMATION_TTL_SECONDS=900

# SSH adapter (task B2a) — DOCUMENTAZIONE, non ancora letto da config.py.
# Il boundary SSH riceve endpoint/credenziali/timeout come modelli tipizzati dal
# chiamante; queste voci descrivono i default e le policy previste quando la
# sessione reale verrà collegata. Non inserire MAI credenziali reali qui: le
# password/chiavi SSH vanno nello store cifrato delle credenziali, mai in chiaro
# nell'ambiente o sulla command line.
# Host-key policy: "strict" (default, host sconosciuto rifiutato) oppure
# "accept_new" (override esplicito e audibile: registra solo host nuovi; una host
# key CAMBIATA è sempre rifiutata). Nessun auto-add silenzioso.
SSH_HOST_KEY_POLICY=strict
# Percorso del known_hosts persistente (trust anchor, permessi 0600).
SSH_KNOWN_HOSTS_PATH=./secrets/known_hosts
# Timeout in secondi: connect / command (durata massima) / idle (nessun output).
SSH_CONNECT_TIMEOUT_SECONDS=10
SSH_COMMAND_TIMEOUT_SECONDS=30
SSH_IDLE_TIMEOUT_SECONDS=15
# Limiti di output (byte) per impedire l'esaurimento di memoria; l'eccesso è
# scartato e segnalato come troncato.
SSH_MAX_STDOUT_BYTES=1048576
SSH_MAX_STDERR_BYTES=262144
# Le scritture reali su destinazione via SSH restano disabilitate per default e
# richiedono destinazione verificata; nessun writer SSH è collegato in B2a.

# Web
VITE_API_BASE_URL=http://localhost:8000
