# Live cPanel characterization — ENV TEMPLATE (placeholders only).
#
# Copy to `.env.live` (gitignored) and fill with DISPOSABLE-lab values ONLY. Never commit the real
# file. Never put these values on a CLI, in logs, or in the sanitized report. See LAB_RUNBOOK.md.
# The live test is skipped unless ALL required gates below are satisfied.

# --- required safety gate (all three must be exactly "1") ---
RUN_LIVE_CPANEL_DESTRUCTIVE_TESTS=
CPANEL_TEST_ACCOUNT_DISPOSABLE=
CPANEL_TEST_ACCOUNT_RESET_APPROVED=

# --- required target selection ---
# Opaque identifier of the disposable endpoint; must appear in the allowlist below.
CPANEL_TEST_ENDPOINT=
# Comma-separated allowlist of disposable endpoint identifiers.
CPANEL_TEST_ENDPOINT_ALLOWLIST=
# A real domain configured on the disposable account (no real MX, no real mail).
CPANEL_TEST_DISPOSABLE_DOMAIN=

# --- production denylist (endpoint MUST NOT appear here) ---
# Comma-separated production endpoint identifiers; adding the lab must not remove any of these.
CPANEL_TEST_PRODUCTION_ENDPOINTS=

# --- gateway shim connection params (documented, NOT valued here) ---
# The gateway (list_domains/list_forwarders/add_forwarder over CpanelClient) needs cPanel API
# access. Provide these ONLY in the gitignored .env.live, or reuse the encrypted-credential store
# (CREDENTIAL_ENCRYPTION_KEY). Leave blank in this template.
CPANEL_TEST_API_HOST=
CPANEL_TEST_API_PORT=
CPANEL_TEST_API_USER=
# Prefer an injected/encrypted token over a plaintext value; never commit a real token.
CPANEL_TEST_API_TOKEN=
